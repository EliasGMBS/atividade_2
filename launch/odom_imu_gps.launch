<!-- =======================================================================
  Launch file: Localização usando Odometria + IMU + GPS
  
  Este launch file configura o EKF para fundir dados de TRÊS fontes:
  odometria das rodas, IMU e GPS. Esta é a configuração mais completa.
  
  Nós lançados:
    1. topic_tools/relay: republica husky_velocity_controller/odom -> /wheel/odom
    2. gps_to_odom.py: converte GPS (NavSatFix) para Odometry no frame odom
    3. ekf_localization_node: filtro EKF com config ekf_odom_imu_gps.yaml
    4. metrics_evaluator.py: avaliador de métricas de localização
  ======================================================================= -->
<launch>

  <!-- ===== Relay da Odometria ===== -->
  <!-- Republica o tópico de odometria do Husky para um tópico padronizado. -->
  <node name="odom_relay" pkg="topic_tools" type="relay"
        args="husky_velocity_controller/odom /wheel/odom" />

  <!-- ===== Conversor GPS -> Odometria ===== -->
  <!-- Converte dados de GPS (sensor_msgs/NavSatFix) do tópico /fix
       para nav_msgs/Odometry no tópico /gps/odom, usando projeção UTM.
       Isso permite que o EKF funda a posição GPS com as outras fontes. -->
  <node name="gps_to_odom" pkg="atividade_2" type="gps_to_odom.py"
        output="screen">
    <remap from="/fix" to="/navsat/fix" />
  </node>

  <!-- ===== Nó EKF ===== -->
  <!-- Carrega a configuração do EKF com odometria + IMU + GPS.
       O nó publica a pose filtrada em /odometry/filtered. -->
  <node name="ekf_localization" pkg="robot_localization" type="ekf_localization_node"
        clear_params="true" output="screen">
    <rosparam command="load" file="$(find atividade_2)/config/ekf_odom_imu_gps.yaml" />
  </node>

  <!-- ===== Avaliador de Métricas ===== -->
  <!-- Nó que compara /odometry/filtered com /gt/odom (ground truth)
       e calcula métricas de erro. -->
  <node name="metrics_evaluator" pkg="atividade_2" type="metrics_evaluator.py"
        output="screen">
    <param name="config_name" value="odom_imu_gps" />
  </node>

</launch>
